PROJECT_NAME           = "lvgl_pc_minimal"
PROJECT_BRIEF          = "Generated API documentation"
OUTPUT_DIRECTORY       = .
OUTPUT_LANGUAGE        = English
USE_MDFILE_AS_MAINPAGE =
FULL_PATH_NAMES        = NO
STRIP_FROM_PATH        = ../../
CREATE_SUBDIRS         = NO
ALLOW_UNICODE_NAMES    = NO

INPUT                  = ../../src
FILE_PATTERNS          = *.c *.h *.cpp *.hpp
RECURSIVE              = YES
EXCLUDE                = ../../src/ui ../../lvgl ../../build ../../build_opencode
EXCLUDE_PATTERNS       = */src/ui/* */CMakeFiles/* */lvgl/* */build/* */build_opencode/*

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
SHOW_FILES             = YES
ALIASES                += description=""

QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO

JAVADOC_AUTOBRIEF      = YES
MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES
INLINE_INHERITED_MEMB  = NO
SORT_MEMBER_DOCS       = YES
OPTIMIZE_OUTPUT_FOR_C  = YES

GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_FILE_EXTENSION    = .html
GENERATE_TREEVIEW      = YES

GENERATE_LATEX         = YES
LATEX_OUTPUT           = latex
USE_PDFLATEX           = YES
LATEX_BATCHMODE        = YES

GENERATE_XML           = YES
XML_OUTPUT             = xml

GENERATE_RTF           = NO
GENERATE_MAN           = NO
GENERATE_DOCBOOK       = NO
GENERATE_QHP           = NO

SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

HAVE_DOT               = NO
